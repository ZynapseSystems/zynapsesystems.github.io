---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import TextMarquee2 from "../components/TextMarquee2.astro";
import GalleryText from "../components/GalleryText.astro";
import ImageMarquee from "../components/ImageMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Plans from "../components/Plans.astro";
import Statements from "../components/Statements.astro";
import Introducing from "../components/Introducing.astro";
import GL from "../components/GL.astro";
import GLPlaces from "../components/GlPlaces.astro";

import logo1 from "../assets/logoipsum-344.svg";
import logo2 from "../assets/logoipsum-350.svg";
import logo3 from "../assets/logoipsum-345.svg";
import logo4 from "../assets/logoipsum-385.svg";
import logo5 from "../assets/logoipsum-375.svg";
import logo6 from "../assets/logoipsum-378.svg";
import logo7 from "../assets/logoipsum-346.svg";
import logo8 from "../assets/logoipsum-331.svg";
---

<Layout title="Zynapse Systems LLC. - Services">

  <HeroHome
    title="Available Services"
    subtitle="Technology leadership, infrastructure optimization, and hands-on support. Designed to strengthen your systems and future-proof your growth."
    cta={{
      title: "Schedule a Free Consultation",
      url: "#plans",
    }}
  />

  <Plans
    title="Services By Category"
    subtitle="Comprehensive IT and technology solutions tailored to your organization."
    items={[
      {
        title: "IT Strategy & Consulting",
        features: [
          { title: "Technology planning and roadmap development" },
          { title: "Software and tool recommendations tailored to your needs" },
          { title: "IT infrastructure assessment and optimization" },
          { title: "Digital transformation consulting" },
          { title: "Technology budget planning and cost optimization" },
          { title: "Vendor evaluation and selection" },
        ],
      },
      {
        title: "Website Services",
        features: [
          { title: "Custom website design and development" },
          { title: "Website management and ongoing maintenance" },
          { title: "Content updates and site modifications" },
          { title: "Website platform migrations" },
          { title: "Performance optimization and troubleshooting" },
          { title: "Site security and backup management" },
        ],
      },
      {
        title: "Domain & Email Management",
        features: [
          { title: "Domain registration and transfers" },
          { title: "DNS configuration and management" },
          { title: "Email system setup and administration" },
          { title: "Email migration between platforms" },
          { title: "User account creation and management" },
          { title: "Email security and spam filtering" },
        ],
      },
      {
        title: "Workspace Administration",
        features: [
          { title: "Google Workspace administration" },
          { title: "Microsoft 365 Business administration" },
          { title: "User provisioning and access control" },
          { title: "Security settings and compliance configuration" },
          { title: "Application integration and workflow automation" },
          { title: "Training and user support" },
        ],
      },
      {
        title: "Software Solutions & Implementation",
        features: [
          { title: "Business software research and recommendations" },
          { title: "Project management tools (Monday.com, Asana, Trello, etc.)" },
          { title: "CRM implementation and configuration" },
          { title: "Grant tracking and management systems" },
          { title: "Workflow automation and integration" },
          { title: "User training and documentation" },
        ],
      },
      {
        title: "Limited Graphic Design",
        features: [
          { title: "Branding elements" },
          { title: "Marketing materials and collateral" },
          { title: "Social media graphics" },
          { title: "Presentation & document templates" },
          { title: "Basic print design" },
        ],
      },
      {
        title: "General IT Support",
        features: [
          { title: "Technical troubleshooting and problem resolution" },
          { title: "Computer and device setup" },
          { title: "Software installation and updates" },
          { title: "Network configuration and support" },
          { title: "Data backup and recovery solutions" },
          { title: "Security best practices and implementation" },
        ],
      },
      {
        title: "Additional Capabilities",
        features: [
          { title: "Training & Documentation" },
          { title: "Data Migration" },
          { title: "Security Consulting" },
          { title: "Compliance Support" },
          { title: "Emergency Support" },
          { title: "Technology Monitoring" },
        ],
      },
    ]}
  />

  <GL />
  <GLPlaces />
</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }
</style>
